---
import '../styles/global.css';
import AgentationDevTool from '../components/Agentation.tsx';
import CopyDiffer from '../components/CopyDiffer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'And/or Labs — the proven OS for adtech growth',
  description = 'We transform early-stage adtech startups through clear positioning, buyer-led content, and AI x GTM enablement.',
  image = '/og.png',
} = Astro.props;

// Absolute URLs for social scrapers — they refuse relative paths.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'And/or Labs',
  url: Astro.site?.toString(),
  logo: new URL('/andor-logo.png', Astro.site).toString(),
  description,
  founder: {
    '@type': 'Person',
    name: 'Vishveshwar Jatain',
    sameAs: 'https://www.linkedin.com/in/vishveshwar-jatain',
  },
  sameAs: [
    'https://www.linkedin.com/in/vishveshwar-jatain',
    'https://x.com/eclecticV',
    'https://github.com/eclecticv',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#ffffff" />

    <!-- Icons rendered from the brand mark (andor-logo.png) — see public/ -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph (LinkedIn, Facebook, Slack, iMessage) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="And/or Labs" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="And/or Labs — the proven OS for adtech growth" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@eclecticV" />
    <meta name="twitter:creator" content="@eclecticV" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <title>{title}</title>
    <!-- Satoshi loads from Fontshare (see global.css @import); Inter/Geist/Spectral are self-hosted. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  </head>
  <body>
    <slot />

    {/* Dev-only visual feedback — annotate the live page, agent reads it via MCP */}
    {import.meta.env.DEV && <AgentationDevTool client:only="react" />}

    {/* Dev-only inline copy editor — edit text in place, copy a diff to hand back */}
    {import.meta.env.DEV && <CopyDiffer />}
  </body>
</html>
