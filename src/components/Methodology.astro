---
// Our methodology — alternating text + bespoke-SVG rows. Each visual is the most
// persuasive artifact for its pillar (positioning map / channel benchmark /
// GTM-stack graph), drawn from the brand tokens. Pillar copy is VERBATIM from
// Site structure.md. Each pillar is marked with a large, faintly-set ordinal.
import Section from './Section.astro';
import SectionHead from './SectionHead.astro';

const pillars = [
  {
    title: 'Positioning & offer design',
    body: 'We craft a differentiated positioning to make it obvious why a buyer should pick you over the alternatives, then pair that with a custom designed site optimized for conversions.',
    viz: 'map',
  },
  {
    title: 'Content engineering',
    body: 'We benchmark your visibility across search, AI chatbots, social, and offsite channels, then set up AI playbooks to close the gap, with human-in-the-loop quality reviews.',
    viz: 'bars',
  },
  {
    title: 'AI x GTM enablement',
    body: 'We enable your growth teams by modernizing your technology stack to cut down on busywork, activate new motions, and deliver real-time sales intelligence.',
    viz: 'graph',
  },
];

// Each channel: `now` = current visibility (navy), `target` = where the AI
// playbooks take it. The PRISM fills the gap between the two — so the rainbow
// literally reads as "the visibility we add." AI is the standout lever.
const channels = [
  { name: 'SEARCH', now: 0.42, target: 0.62 },
  { name: 'AI', now: 0.26, target: 0.84 },
  { name: 'SOCIAL', now: 0.3, target: 0.46 },
  { name: 'OFFSITE', now: 0.2, target: 0.34 },
];
const TRACK_X = 104;
const TRACK_W = 188;
---

<Section id="methodology" tone="navy">
  <SectionHead
    title="Methodology"
    lede="And/or Labs is the only full-stack GTM partner that focuses on transforming how adtech startups show up in the market and play the competitive field."
    invert
  />

  <div class="relative mt-14 flex flex-col">
    {/* Shared prism defs — one rainbow gradient + halo + flow arrowhead, reused
        by all three visuals so the brand signature is identical across them. */}
    <svg width="0" height="0" class="absolute" aria-hidden="true">
      <defs>
        <linearGradient id="prismGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#3b82f6" />
          <stop offset="28%" stop-color="#8b5cf6" />
          <stop offset="52%" stop-color="#ec4899" />
          <stop offset="76%" stop-color="#ea580c" />
          <stop offset="100%" stop-color="#059669" />
        </linearGradient>
        <radialGradient id="prismHalo">
          <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.30" />
          <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0" />
        </radialGradient>
        <marker id="flow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0 0 L6 3 L0 6 z" fill="#1e1d70" opacity="0.55" />
        </marker>
      </defs>
    </svg>
    {
      pillars.map((p, i) => {
        const flip = i % 2 === 1;
        return (
          <div class="relative z-10 grid items-center gap-10 py-10 lg:grid-cols-2 lg:gap-16 lg:py-12">
            {/* text column */}
            <div class:list={['flex flex-col items-start gap-2', flip && 'lg:order-2']}>
              <span class="font-satoshi text-display leading-none text-white/25">
                0{i + 1}
              </span>
              <h3 class="font-satoshi text-h3 text-canvas-white">
                {p.title}
              </h3>
              <p class="max-w-[46ch] text-lede text-white/75">{p.body}</p>
            </div>

            {/* bespoke visual — consistent 4:3 frame, prism top edge */}
            <div class:list={[flip && 'lg:order-1']}>
              <div
                class:list={[
                  'viz-reveal relative aspect-[4/3] w-full max-w-[380px] overflow-hidden rounded-xl border border-border-light bg-subtle-ash',
                  flip ? 'lg:mr-auto' : 'lg:ml-auto',
                ]}
              >
                <div class="prism-line absolute inset-x-0 top-0 z-10 h-px opacity-60" />

                {p.viz === 'map' && (
                  <svg viewBox="0 0 320 240" class="h-full w-full" aria-hidden="true">
                    {/* axes */}
                    <line x1="160" y1="28" x2="160" y2="214" stroke="#e5e5e5" stroke-width="1.5" />
                    <line x1="36" y1="120" x2="292" y2="120" stroke="#e5e5e5" stroke-width="1.5" />
                    <text x="288" y="135" text-anchor="end" font-family="ui-monospace,monospace" font-size="8" letter-spacing="1.2" fill="#9a99c0">DIFFERENTIATION</text>
                    <text x="168" y="40" font-family="ui-monospace,monospace" font-size="8" letter-spacing="1.2" fill="#9a99c0">VALUE</text>
                    {/* the crowd — a tight, overlapping pack of look-alikes (low differentiation) */}
                    <g fill="#1e1d70" opacity="0.20">
                      <circle cx="92" cy="150" r="7" />
                      <circle cx="108" cy="138" r="7" />
                      <circle cx="102" cy="164" r="7" />
                      <circle cx="120" cy="152" r="7" />
                      <circle cx="88" cy="136" r="7" />
                      <circle cx="118" cy="168" r="7" />
                      <circle cx="130" cy="140" r="7" />
                    </g>
                    {/* the move — a dashed trajectory breaking out of the pack */}
                    <path d="M136 148 Q 198 118 226 86" fill="none" stroke="#1e1d70" stroke-width="1.5" stroke-dasharray="2 4" opacity="0.5" />
                    {/* You — alone in the high-value / high-differentiation space */}
                    <circle cx="234" cy="74" r="22" fill="url(#prismHalo)" />
                    <circle cx="234" cy="74" r="9" fill="url(#prismGrad)" />
                    <text x="234" y="48" text-anchor="middle" font-family="ui-monospace,monospace" font-size="10" font-weight="600" fill="#1e1d70">You</text>
                  </svg>
                )}

                {p.viz === 'bars' && (
                  <svg viewBox="0 0 320 240" class="h-full w-full" aria-hidden="true">
                    {channels.map((c, idx) => {
                      const cy = 52 + idx * 47;
                      const nowW = Math.round(TRACK_W * c.now);
                      const targetW = Math.round(TRACK_W * c.target);
                      return (
                        <>
                          <text x="92" y={cy + 4} text-anchor="end" font-family="ui-monospace,monospace" font-size="10" letter-spacing="0.5" fill="#1e1d70">{c.name}</text>
                          {/* ceiling track */}
                          <rect x={TRACK_X} y={cy - 7} width={TRACK_W} height="14" rx="7" fill="#e6e6ef" />
                          {/* prism fills to the target — the visibility we add */}
                          <rect x={TRACK_X} y={cy - 7} width={targetW} height="14" rx="7" fill="url(#prismGrad)" />
                          {/* navy current sits on top — where you are today */}
                          <rect x={TRACK_X} y={cy - 7} width={nowW} height="14" rx="7" fill="#1e1d70" />
                        </>
                      );
                    })}
                  </svg>
                )}

                {p.viz === 'graph' && (
                  <svg viewBox="0 0 320 240" class="h-full w-full" aria-hidden="true">
                    {/* directional flow: data in → AI → real-time intelligence out */}
                    <line x1="100" y1="120" x2="121" y2="120" stroke="#1e1d70" stroke-width="1.5" opacity="0.5" marker-end="url(#flow)" />
                    <line x1="196" y1="116" x2="221" y2="74" stroke="#1e1d70" stroke-width="1.5" opacity="0.5" marker-end="url(#flow)" />
                    <line x1="198" y1="120" x2="221" y2="120" stroke="#1e1d70" stroke-width="1.5" opacity="0.5" marker-end="url(#flow)" />
                    <line x1="196" y1="124" x2="221" y2="166" stroke="#1e1d70" stroke-width="1.5" opacity="0.5" marker-end="url(#flow)" />
                    {/* input node */}
                    <rect x="34" y="106" width="64" height="28" rx="9" fill="#ffffff" stroke="#1e1d70" stroke-width="1.5" />
                    <text x="66" y="124" text-anchor="middle" font-family="ui-monospace,monospace" font-size="11" font-weight="600" fill="#1e1d70">DATA</text>
                    {/* output nodes */}
                    <rect x="226" y="56" width="64" height="28" rx="9" fill="#ffffff" stroke="#1e1d70" stroke-width="1.5" />
                    <text x="258" y="74" text-anchor="middle" font-family="ui-monospace,monospace" font-size="11" font-weight="600" fill="#1e1d70">CRM</text>
                    <rect x="226" y="106" width="64" height="28" rx="9" fill="#ffffff" stroke="#1e1d70" stroke-width="1.5" />
                    <text x="258" y="124" text-anchor="middle" font-family="ui-monospace,monospace" font-size="11" font-weight="600" fill="#1e1d70">ADS</text>
                    <rect x="226" y="156" width="64" height="28" rx="9" fill="#ffffff" stroke="#1e1d70" stroke-width="1.5" />
                    <text x="258" y="174" text-anchor="middle" font-family="ui-monospace,monospace" font-size="11" font-weight="600" fill="#1e1d70">TEAM</text>
                    {/* the AI core — the prism engine at the center */}
                    <rect x="125" y="103" width="70" height="34" rx="11" fill="url(#prismGrad)" />
                    <text x="160" y="124" text-anchor="middle" font-family="ui-monospace,monospace" font-size="12" font-weight="700" fill="#ffffff">AI</text>
                  </svg>
                )}
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</Section>

<style>
  /* Subtle scroll-entry reveal — one restrained fade-up per visual. No JS.
     Bounded by the "don't over-design" anti-goal: frame-level only, not
     per-element choreography. */
  .viz-reveal {
    opacity: 1; /* fallback when scroll timelines unsupported */
  }

  @keyframes viz-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @supports (animation-timeline: view()) {
    .viz-reveal {
      animation: viz-rise ease-out both;
      animation-timeline: view();
      animation-range: entry 5% cover 28%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .viz-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
