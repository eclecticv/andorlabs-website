---
// How we work — two engagement plans. `featured` marks the currently-emphasized
// engagement: Transformation Sprint (the 4-week sprint) gets the accent border + filled
// CTA. The Fractional retainer is intentionally de-emphasized (hairline border +
// ghost "Join waitlist") because it is not actively booking right now.
import Section from './Section.astro';
import SectionHead from './SectionHead.astro';
import Button from './Button.astro';
import { Icon } from 'astro-icon/components';

// Plan copy is VERBATIM from Site structure.md.
const plans = [
  {
    featured: false,
    tag: 'Retainer',
    name: 'Fractional Head of Marketing',
    blurb: 'Get a 2x-exited AdTech marketer embedded in your team and owning the roadmap.',
    price: '$7.5k',
    cadence: '/mo',
    features: ['Custom roadmap development', 'Weekly strategy call', 'Email & Slack access'],
    cta: 'Join waitlist',
  },
  {
    featured: true,
    tag: '4-week sprint',
    name: 'Transformation Sprint',
    blurb: 'Look like a Series B startup in one month—without the big-agency price tag.',
    price: '$10k',
    cadence: 'one-time',
    features: ['Brand & design refresh', 'Re-worked positioning', 'New, AI-ready website'],
    cta: 'Reserve your spot',
  },
];
---

<Section id="how-we-work" tone="white" class="dot-grid">
  <SectionHead
    title="How we work"
    lede="No agency bloat, endless stakeholder calls, or interns learning on your dime—just a senior marketing IC who has scaled two adtech startups to exit."
  />

  <div class="mx-auto mt-14 grid max-w-[var(--width-narrow)] items-stretch gap-6 md:grid-cols-2">
    {
      plans.map((p) => {
        // Both tiers are dark surfaces. The featured plan is the branded hero
        // (deep navy + prism signature + white CTA); the retainer is a quieter
        // neutral charcoal — a complementary dark that keeps the two distinct
        // rather than an identical dark grid.
        const f = p.featured;
        return (
          <div
            class:list={[
              'relative flex flex-col overflow-hidden rounded-2xl p-8 text-canvas-white ring-1 ring-white/10 transition-[translate,box-shadow] duration-200 ease-out hover:-translate-y-0.5',
              f
                ? 'bg-gradient-to-b from-logo-navy to-deep-navy shadow-[0_24px_50px_-12px_rgba(21,20,78,0.55)] hover:shadow-[0_32px_60px_-12px_rgba(21,20,78,0.62)]'
                : 'bg-gradient-to-b from-prism-rose to-prism-rose-deep shadow-[0_24px_50px_-12px_rgba(86,24,47,0.5)] hover:shadow-[0_32px_60px_-12px_rgba(86,24,47,0.6)]',
            ]}
          >
            {/* prism hairline — the signature, reserved for the featured hero */}
            {f && <div class="prism-line absolute inset-x-0 top-0 z-10 h-px opacity-80" />}

            <span class="inline-flex w-fit items-center rounded-full bg-white/10 px-2.5 py-1 font-mono text-eyebrow uppercase text-white/70">
              {p.tag}
            </span>

            <h3 class="mt-4 font-satoshi text-h4 text-canvas-white">{p.name}</h3>
            <p class="mt-2 max-w-[34ch] text-body text-white/70">{p.blurb}</p>

            <div class="mt-5 flex items-baseline gap-1.5">
              <span class="font-satoshi text-[1.5rem] font-bold leading-none tracking-[-0.02em] text-canvas-white">
                {p.price}
              </span>
              {p.cadence && <span class="text-meta font-medium text-white/55">{p.cadence}</span>}
            </div>

            <ul class="mt-6 flex flex-col gap-3 border-t border-white/15 pt-6">
              {p.features.map((feat) => (
                <li class="flex items-center gap-2.5 text-meta text-white/85">
                  <Icon name="lucide:check" class="h-4 w-4 shrink-0 text-white/90" />
                  {feat}
                </li>
              ))}
            </ul>

            <div class="mt-auto pt-8">
              <Button
                href="https://tally.so/r/ZjaeZV"
                target="_blank"
                rel="noopener noreferrer"
                variant={f ? 'light' : 'outline'}
                class="w-full"
              >
                {p.cta}
              </Button>
            </div>
          </div>
        );
      })
    }
  </div>

  <p class="mt-10 text-center text-body text-steel-gray">
    Have a custom project?{' '}
    <a href="https://tally.so/r/ZjaeZV" target="_blank" rel="noopener noreferrer" class="font-semibold text-ink-black underline underline-offset-4 decoration-border-muted hover:decoration-ink-black">
      Let's talk &rarr;
    </a>
  </p>
</Section>
