---
// "Featured in" earned-media strip — real press logo SVGs as muted grayscale
// marks that lift to ink on hover. One quiet label, one evenly-spaced row.
interface Props {
  label?: string;
  class?: string;
}
const { label = 'bylines and quotes in', class: className = '' } = Astro.props;

const press = [
  { name: 'Forbes', src: '/logos/forbes.svg' },
  { name: 'Digiday', src: '/logos/digiday.svg' },
  { name: 'Adage', src: '/logos/adage.svg' },
  { name: 'eMarketer', src: '/logos/emarketer.svg' },
  { name: 'ExchangeWire', src: '/logos/exchangewire.svg' },
  { name: 'The Next Web', src: '/logos/thenextweb.svg' },
];
---

<div class:list={['flex flex-col items-center gap-6', className]}>
  <span class="font-mono text-eyebrow uppercase tracking-[0.12em] text-muted">{label}</span>
  <ul class="flex flex-wrap items-center justify-center gap-x-9 gap-y-5 sm:flex-nowrap sm:gap-x-11">
    {
      press.map((p) => (
        <li class="flex">
          <img
            src={p.src}
            alt={p.name}
            class="h-6 w-auto opacity-50 grayscale transition-all duration-200 hover:opacity-100 hover:grayscale-0"
            loading="lazy"
          />
        </li>
      ))
    }
  </ul>
</div>
